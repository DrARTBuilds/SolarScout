# SolarScout V2 - Client Environment Variables Template
# Copy this file to '.env' and fill in your actual credentials.
# Note: DO NOT commit your actual '.env' file to Git!

# 1. Backend Gateway Integration API
# In development, point to your local Express server (usually http://localhost:3000/api).
# In production, point to your deployed Express gateway (e.g., https://your-solar-scout-api.railway.app/api).
VITE_API_URL=http://localhost:3000/api

# 2. Firebase SDK Client Credentials
# Create a web application in the Firebase Console to obtain these values.
VITE_FIREBASE_API_KEY=AIzaSyCbmat_YOUR_ACTUAL_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=solarscout-22824.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=solarscout-22824
VITE_FIREBASE_STORAGE_BUCKET=solarscout-22824.firebasestorage.app
